# Set this to the final model repository after the user approves publication.
LFM25_MODEL_BASE_URL=https://huggingface.co/PrismPhi/lfm25-350m-q6a-npu-edition/resolve/main

# Set this when the QNN-enabled Python is not the default python3.
LFM25_PYTHON=/path/to/qnn-venv/bin/python

# Optional runtime overrides.
LFM25_PORT=18080
LFM25_HOST=127.0.0.1
