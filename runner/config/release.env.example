# Optional asset mirror override. The public Hugging Face repository is the built-in default.
LFM2_5_MODEL_BASE_URL=https://huggingface.co/PrismPhi/lfm2.5-350m-q6a-qcs6490-qnn-npu/resolve/main

# Set this when the QNN-enabled Python is not the default python3.
LFM2_5_PYTHON=/path/to/qnn-venv/bin/python

# Optional runtime overrides.
LFM2_5_STATE_DIR=/path/to/state
LFM2_5_PORT=18080
LFM2_5_HOST=127.0.0.1
